<Window x:Class="PicoAudioCore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PicoAudioCore  v2.1" Icon="/PicoAudioCore;component/app.ico" Height="590" Width="896"
        Background="#1e1e2e" Foreground="White"
        FontFamily="Cascadia Code, Cascadia Mono, Consolas"
        FontSize="13"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- ── Base console button ─────────────────────────────────────────── -->
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#2c2c44" Offset="0"/>
                        <GradientStop Color="#18182a" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground"      Value="#c0c8e8"/>
            <Setter Property="BorderBrush"     Value="#383858"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3a3a56" Offset="0"/>
                                            <GradientStop Color="#22223a" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4e4e72"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#10101e" Offset="0"/>
                                            <GradientStop Color="#20203a" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2a2a44"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background"      Value="#14305a"/>
            <Setter Property="Foreground"      Value="#7ab4f8"/>
            <Setter Property="BorderBrush"     Value="#3a6aaa"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1a3e70"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5a90d8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0c2040"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HkPlayBtn" TargetType="Button">
            <Setter Property="Background"      Value="#0a1e0a"/>
            <Setter Property="Foreground"      Value="#5acc5a"/>
            <Setter Property="BorderBrush"     Value="#1e4a1e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0f2e0f"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2e6a2e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#060e06"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" Background="#383858" CornerRadius="3"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4e4e72"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7aa2f7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Width"           Value="6"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="6">
                            <Border Background="#14141e" CornerRadius="3" Margin="2,4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkScrollThumb}" MinHeight="20"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AVFaderV" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Focusable"   Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid HorizontalAlignment="Center">
                            <Border Width="3" Background="#1a1a2e" CornerRadius="1"
                                    VerticalAlignment="Stretch" HorizontalAlignment="Center"/>
                            <Rectangle Width="9" Height="1" Fill="#3a3a5a"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Width="3" Background="#3d5a99" HorizontalAlignment="Center" CornerRadius="0,0,1,1"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="Cap" Width="22" Height="10" CornerRadius="2"
                                                        Background="#7aa2f7" BorderBrush="#4a72c7" BorderThickness="1">
                                                    <Rectangle Width="13" Height="1" Fill="#0d1430"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Cap" Property="Background" Value="#a0bfff"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="Cap" Property="Background" Value="#c0d8ff"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Width="3" Background="Transparent" HorizontalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AVFaderH" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Focusable"   Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="3" Background="#1a1a2e" CornerRadius="1"
                                    VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#7aa2f7" VerticalAlignment="Center" CornerRadius="1,0,0,1"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="Cap" Width="11" Height="22" CornerRadius="2"
                                                        Background="#7aa2f7" BorderBrush="#4a72c7" BorderThickness="1">
                                                    <Rectangle Width="1" Height="12" Fill="#0d1430"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Cap" Property="Background" Value="#a0bfff"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="Cap" Property="Background" Value="#c0d8ff"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#252535" VerticalAlignment="Center" CornerRadius="0,1,1,0"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Main page tab style ──────────────────────────────────────────── -->
        <Style x:Key="PageTab" TargetType="TabItem">
            <Setter Property="Background"   Value="#14141e"/>
            <Setter Property="Foreground"   Value="#6c7086"/>
            <Setter Property="BorderBrush"  Value="#383858"/>
            <Setter Property="Padding"      Value="22,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#383858" BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}"
                                Margin="0,0,3,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1e1e2e"/>
                                <Setter Property="Foreground" Value="#7aa2f7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1c1c30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="190"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Connection bar (always visible) ──────────────────────────────── -->
        <Border Grid.Row="0" Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#cdd6f4"/>
                <ComboBox  Grid.Column="1" x:Name="CbPort" Height="28" BorderBrush="#45475a">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#1e1e2e"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#45475a"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1" CornerRadius="4"/>
                                            <ContentPresenter x:Name="ContentSite"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              Margin="8,0,28,0" VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"
                                                              TextElement.Foreground="White"/>
                                            <ToggleButton Focusable="False"
                                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                          ClickMode="Press" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                                        <Setter Property="Background"            Value="Transparent"/>
                                                        <Setter Property="BorderThickness"       Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="Transparent"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <TextBlock Text="▾" Foreground="White" FontSize="13"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Margin="0,0,8,0" IsHitTestVisible="False"/>
                                            <Popup x:Name="Popup" Placement="Bottom"
                                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                                    <Border Background="#313244" BorderBrush="#45475a" BorderThickness="1" CornerRadius="4">
                                                        <ScrollViewer>
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Grid>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="ItemContainerStyle">
                                <Setter.Value>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#313244"/>
                                        <Setter Property="Padding"    Value="8,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBoxItem">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                        <TextBlock Text="{TemplateBinding Content}" Foreground="White" FontSize="13"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsHighlighted" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#585b70"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>
                <Button    Grid.Column="2" x:Name="BtnRefresh" Content="⟳" Style="{StaticResource DarkBtn}" Margin="6,0" Width="32" Click="BtnRefresh_Click"/>
                <Button    Grid.Column="3" x:Name="BtnConnect" Content="Connect" Style="{StaticResource AccentBtn}" Width="100" Click="BtnConnect_Click"/>
                <TextBlock Grid.Column="4" x:Name="TbFirmware" Text="" Foreground="#6c7086" FontSize="13"                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="BtnSendFile" Content="📤 Send File" Style="{StaticResource DarkBtn}"
                            Padding="10,5" FontSize="13" IsEnabled="False" Click="BtnSendFile_Click"/>
                </StackPanel>
                <Ellipse Grid.Column="5" x:Name="StatusDot" Width="12" Height="12"
                         Fill="#f38ba8" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Upload progress (hidden when idle) -->
        <Border Grid.Row="0" x:Name="UploadPanel" Visibility="Collapsed" VerticalAlignment="Bottom"
                Background="#1e1e3e" CornerRadius="0,0,6,6" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="UploadLabel" Text="📤" Foreground="#cdd6f4"
                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                <ProgressBar Grid.Column="1" x:Name="UploadBar" Height="14" Minimum="0" Maximum="100"
                             Background="#313244" Foreground="#89b4fa" BorderThickness="0"/>
                <TextBlock Grid.Column="2" x:Name="UploadPct" Text="0%" Foreground="#cdd6f4"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           FontFamily="Consolas" FontSize="13"/>
            </Grid>
        </Border>

        <!-- ── Main page TabControl ─────────────────────────────────────────── -->
        <TabControl Grid.Row="1" Background="Transparent" BorderBrush="#383858" BorderThickness="1">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource PageTab}"/>
            </TabControl.Resources>

            <!-- ════════════════════════════════════════════════════════════════
                 PAGE 1 — Player
                 ════════════════════════════════════════════════════════════════ -->
            <TabItem Header="▶  Player">
                <Grid Background="#1e1e2e" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Transport -->
                    <Border Grid.Row="0" Background="#313244" CornerRadius="6" Padding="16,12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBox x:Name="TbNowPlaying" Text="— Not connected —"
                                     FontSize="14" FontWeight="Bold" Foreground="#cdd6f4"
                                     HorizontalAlignment="Center" Margin="0,0,0,4"
                                     IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent" TextAlignment="Center"
                                     SelectionBrush="#89b4fa" Cursor="IBeam"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock x:Name="TbElapsed" Text="--:--" FontFamily="Consolas" FontSize="13"
                                           Foreground="#a6e3a1" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TbTrackInfo" Text="" FontSize="13"
                                           Foreground="#6c7086" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="BtnPrev"  Content="⏮  PREV"  Style="{StaticResource DarkBtn}" Foreground="#7aaaee" Width="90" Margin="4,0" IsEnabled="False" Click="BtnPrev_Click"/>
                                <Button x:Name="BtnPlay"  Content="▶  PLAY"  Style="{StaticResource DarkBtn}" Foreground="#5acc5a" Width="90" Margin="4,0" IsEnabled="False" Click="BtnPlay_Click"/>
                                <Button x:Name="BtnPause" Content="⏸  PAUSE" Style="{StaticResource DarkBtn}" Foreground="#ccaa40" Width="90" Margin="4,0" IsEnabled="False" Click="BtnPause_Click"/>
                                <Button x:Name="BtnStop"  Content="⏹  STOP"  Style="{StaticResource DarkBtn}" Foreground="#cc5a5a" Width="90" Margin="4,0" IsEnabled="False" Click="BtnStop_Click"/>
                                <Button x:Name="BtnNext"  Content="NEXT  ⏭" Style="{StaticResource DarkBtn}" Foreground="#7aaaee" Width="90" Margin="4,0" IsEnabled="False" Click="BtnNext_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <TextBlock Text="Go to:" VerticalAlignment="Center" Foreground="#a6adc8" Margin="0,0,8,0"/>
                                <TextBox x:Name="TbGoto" Width="220" Background="#1e1e2e" Foreground="White"
                                         BorderBrush="#45475a" Padding="6,4" KeyDown="TbGoto_KeyDown"
                                         ToolTip="Filename without extension, press Enter"/>
                                <Button x:Name="BtnGoto" Content="Go" Style="{StaticResource DarkBtn}"
                                        Width="48" Margin="6,0,0,0" IsEnabled="False" Click="BtnGoto_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Playback mode -->
                    <Border Grid.Row="1" Background="#313244" CornerRadius="6" Padding="16,10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Repeat:" VerticalAlignment="Center" Foreground="#a6adc8" Width="60"/>
                                    <Button x:Name="BtnRepeatOne"    Content="⟳  One"    Style="{StaticResource DarkBtn}" Width="90" Margin="0,0,6,0" IsEnabled="False" Click="BtnRepeatOne_Click"/>
                                    <Button x:Name="BtnRepeatAll"    Content="⟳  All"    Style="{StaticResource DarkBtn}" Width="90" Margin="0,0,6,0" IsEnabled="False" Click="BtnRepeatAll_Click"/>
                                    <Button x:Name="BtnRepeatOff"    Content="✕  Off"    Style="{StaticResource DarkBtn}" Width="90" Margin="0,0,6,0" IsEnabled="False" Click="BtnRepeatOff_Click"/>
                                    <Button x:Name="BtnRepeatSingle" Content="1  Single" Style="{StaticResource DarkBtn}" Width="90" Margin="0,0,0,0" IsEnabled="False" Click="BtnRepeatSingle_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="AutoPlay:" VerticalAlignment="Center" Foreground="#a6adc8" Width="60"/>
                                    <Button x:Name="BtnAutoPlay" Content="▶  Auto On" Style="{StaticResource DarkBtn}" Width="110" IsEnabled="False" Click="BtnAutoPlay_Click"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#1e1e2e" CornerRadius="4" Margin="16,0,0,0" Padding="10,6">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TbFileCodec"      Text="—" Foreground="#89b4fa" FontFamily="Consolas" FontSize="13"/>
                                    <TextBlock x:Name="TbFileSampleRate" Text=""  Foreground="#a6adc8" FontFamily="Consolas" FontSize="13" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Time sync + Volume -->
                    <Border Grid.Row="2" Background="#313244" CornerRadius="6" Padding="16,10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="RTC:" VerticalAlignment="Center" Foreground="#a6adc8" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TbPcTime" Text="--:--:--" FontFamily="Consolas" FontSize="14"
                                           Foreground="#a6e3a1" VerticalAlignment="Center" Width="180"/>
                                <Button x:Name="BtnSyncTime" Content="Sync PC Time → Board" Style="{StaticResource DarkBtn}"
                                        Margin="12,0,0,0" IsEnabled="False" Click="BtnSyncTime_Click"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                <TextBlock Text="Vol:" Foreground="#a6adc8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Slider x:Name="SlVolume" Minimum="0" Maximum="100" Value="80" Width="140"
                                        Style="{StaticResource AVFaderH}"
                                        VerticalAlignment="Center" IsEnabled="False"
                                        ValueChanged="SlVolume_ValueChanged"/>
                                <TextBlock x:Name="TbVolume" Text="80%" Foreground="#cdd6f4"                                           FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0" Width="36"/>
                                <Border x:Name="MonoToggleBorder" Width="90" Height="24" CornerRadius="12"
                                        Background="#45475a" Margin="12,0,0,0" Cursor="Hand"
                                        MouseLeftButtonUp="MonoToggle_Click" IsEnabled="False">
                                    <Grid>
                                        <TextBlock x:Name="TbMonoLabel" Text="STEREO" FontSize="13" FontWeight="Bold"
                                                   Foreground="#a6adc8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse x:Name="MonoThumb" Width="18" Height="18" Fill="#cdd6f4"
                                                 HorizontalAlignment="Left" Margin="3,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 32-Band EQ -->
                    <Border Grid.Row="3" Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="32-Band EQ" Foreground="#a6adc8" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button x:Name="BtnEqReset" Content="Flat Reset" Style="{StaticResource DarkBtn}"
                                        FontSize="13" Padding="8,3" IsEnabled="False" Click="BtnEqReset_Click"/>
                                <TextBlock Text="  0=-12dB  100=flat  200=+12dB" Foreground="#45475a"
                                           FontSize="13" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <StackPanel x:Name="EqPanel" Grid.Row="1" Orientation="Horizontal"/>
                        </Grid>
                    </Border>

                    <!-- Serial Log -->
                    <Border Grid.Row="4" Background="#181825" CornerRadius="6" Padding="2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                                <TextBlock Text="Serial Log" Foreground="#6c7086" FontSize="13"/>
                                <Button x:Name="BtnClearLog" Content="Clear" Style="{StaticResource DarkBtn}"
                                        FontSize="13" Padding="6,2" Margin="8,0,0,0" Click="BtnClearLog_Click"/>
                            </StackPanel>
                            <TextBox x:Name="TbLog" Grid.Row="1"
                                     FontFamily="Consolas" FontSize="13"
                                     Foreground="#cdd6f4" Background="Transparent"
                                     BorderThickness="0" Padding="8,4"
                                     TextWrapping="Wrap" IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     AcceptsReturn="True" Cursor="IBeam">
                                <TextBox.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                                </TextBox.Resources>
                            </TextBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════════════
                 PAGE 2 — Schedule
                 ════════════════════════════════════════════════════════════════ -->
            <TabItem Header="🕐 Schedule">
                <Grid Background="#1e1e2e" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column headers -->
                    <Grid Grid.Row="0" Margin="4,0,4,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="162"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="Start"                   Foreground="#6c7086" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Stop"                    Foreground="#f38ba8" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="Tracks (comma-sep, no ext)" Foreground="#6c7086" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        <TextBlock Grid.Column="4" Text="Loops"                   Foreground="#6c7086" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="Mo   Tu   We   Th   Fr   Sa   Su" Foreground="#6c7086" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="1" Margin="4,0,4,10">

                        <!-- Mode selector -->
                        <Border Background="#181825" CornerRadius="6" Padding="10,6" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="โหมด:" Foreground="#6c7086" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <RadioButton x:Name="RbPicoScheduler" Tag="pico" IsChecked="True"
                                             Foreground="#cdd6f4" FontSize="13" VerticalAlignment="Center"
                                             Margin="0,0,20,0" Checked="SchedModeChanged">
                                    <RadioButton.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🤖 " FontSize="13"/>
                                            <TextBlock Text="Pico Scheduler" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton.Content>
                                </RadioButton>
                                <RadioButton x:Name="RbGuiScheduler" Tag="gui"
                                             Foreground="#cdd6f4" FontSize="13" VerticalAlignment="Center"
                                             Checked="SchedModeChanged">
                                    <RadioButton.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🖥️ " FontSize="13"/>
                                            <TextBlock Text="GUI Scheduler (PC controls)" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton.Content>
                                </RadioButton>
                                <TextBlock Foreground="#585b70" FontSize="13" VerticalAlignment="Center" Margin="20,0,0,0"
                                           Text="Pico = Pico ดูเวลาเอง  |  GUI = PC สั่งเล่นตามเวลา (Pico scheduler หยุดชั่วคราว — entries ยังอยู่)"/>
                            </StackPanel>
                        </Border>

                        <!-- Buttons row -->
                        <WrapPanel Orientation="Horizontal">
                            <Button x:Name="BtnAddSchedule"   Content="＋  Add Entry" Style="{StaticResource DarkBtn}"
                                    FontSize="13" Padding="14,6" Click="BtnAddSchedule_Click"/>
                            <Button x:Name="BtnClearSchedule" Content="Clear All"     Style="{StaticResource DarkBtn}"
                                    FontSize="13" Padding="14,6" Margin="8,0,0,0"     Click="BtnClearSchedule_Click"/>
                            <Rectangle Width="1" Fill="#383858" Margin="14,4"/>
                            <Button x:Name="BtnSendToPico" Style="{StaticResource AccentBtn}"
                                    FontSize="13" Padding="14,6" IsEnabled="False" Click="BtnSendToPico_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↓ " FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Send → Pico" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnPullFromPico" Style="{StaticResource DarkBtn}"
                                    FontSize="13" Padding="14,6" Margin="8,0,0,0" IsEnabled="False" Click="BtnPullFromPico_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↑ " FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Pull ← Pico" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Rectangle Width="1" Fill="#383858" Margin="14,4"/>
                            <Button x:Name="BtnSaveSchedFile" Content="💾  Save File" Style="{StaticResource DarkBtn}"
                                    FontSize="13" Padding="14,6" Click="BtnSaveSchedFile_Click"/>
                            <Button x:Name="BtnLoadSchedFile" Content="📂  Load File" Style="{StaticResource DarkBtn}"
                                    FontSize="13" Padding="8,6" Margin="8,0,0,0"  Click="BtnLoadSchedFile_Click"/>
                            <TextBlock x:Name="TbSchedStatus" Text="" Foreground="#5acc5a"
                                       FontSize="13" FontFamily="Consolas" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Schedule rows -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SchedulePanel" Margin="4,0,4,4"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════════════
                 PAGE 3 — Help
                 ════════════════════════════════════════════════════════════════ -->
            <TabItem Header="❓  Help">
                <ScrollViewer Background="#1e1e2e" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="16,12,16,16">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                    </ScrollViewer.Resources>
                    <StackPanel>

                        <!-- Title -->
                        <TextBlock Text="PicoAudioCore — คู่มือการใช้งาน"
                                   Foreground="#cdd6f4" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- ── Connection ── -->
                        <TextBlock Text="การเชื่อมต่อ" Foreground="#89b4fa" FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" Margin="0,0,0,4">
                            1. เสียบ Pico 2 ผ่าน USB&#10;2. เลือก COM port จาก dropdown ด้านบน&#10;3. คลิก Connect — สถานะจะเปลี่ยนเป็นสีเขียวเมื่อเชื่อมต่อสำเร็จ
                        </TextBlock>

                        <Rectangle Height="1" Fill="#313244" Margin="0,12,0,12"/>

                        <!-- ── Player ── -->
                        <TextBlock Text="แท็บ Player" Foreground="#89b4fa" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <!-- headers -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ปุ่ม / ช่อง" Foreground="#585b70" FontSize="13" FontFamily="Consolas" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="หน้าที่"     Foreground="#585b70" FontSize="13" FontFamily="Consolas" Margin="8,0,0,4"/>
                            <!-- rows -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Play"        Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="เล่น / ยกเลิก pause" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Pause"       Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="หยุดชั่วคราว" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Stop"        Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="หยุด" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="◀ Prev / Next ▶" Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="เพลงก่อนหน้า / ถัดไป" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Volume slider" Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="ระดับเสียง 0–100 (บันทึกลง SD อัตโนมัติ)" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Mono"        Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="สลับโหมด mono / stereo" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Track list"  Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="ดับเบิลคลิกเพื่อกระโดดไปยัง track นั้น" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#313244" Margin="0,12,0,12"/>

                        <!-- ── EQ ── -->
                        <TextBlock Text="แท็บ EQ" Foreground="#89b4fa" FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" FontSize="13" Margin="0,0,0,4">
                            EQ 32 band — ปรับ slider แต่ละ band ได้ตั้งแต่ −12 dB ถึง +12 dB
                        </TextBlock>
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ปรับ slider"    Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="ส่งคำสั่ง eq band ไปยัง Pico ทันที และ sync กลับเมื่อเชื่อมต่อ" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Reset"          Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="คืน EQ ทุก band เป็น flat (0 dB)" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#313244" Margin="0,12,0,12"/>

                        <!-- ── Schedule ── -->
                        <TextBlock Text="แท็บ Schedule" Foreground="#89b4fa" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" FontSize="13" Margin="0,0,0,8">
                            ตั้งให้ Pico เล่นเพลงอัตโนมัติตามวันและเวลาที่กำหนด
                        </TextBlock>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ช่อง"          Foreground="#585b70" FontSize="13" FontFamily="Consolas" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="รายละเอียด"    Foreground="#585b70" FontSize="13" FontFamily="Consolas" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="✓ (checkbox)"  Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="เปิด/ปิด entry นี้" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Start"          Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="เวลาเริ่มเล่น (HH MM สองช่องแยก)" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Stop"           Foreground="#f38ba8" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="เวลาหยุด — ว่างไว้หากไม่ต้องการ" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Tracks"         Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0">
                                ชื่อไฟล์คั่นด้วย comma ไม่ต้องใส่นามสกุล&#10;ตัวอย่าง: <Run Foreground="#fab387">song1,jazz2,bgm</Run>
                            </TextBlock>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Loops"          Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="จำนวนรอบ playlist  (0 = วนไม่รู้จบ)" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Days"            Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="เลือกวันที่จะเล่น จันทร์–อาทิตย์" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="🗑 (ลบ)"         Foreground="#a6e3a1" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="ลบ entry แถวนั้น" Foreground="#cdd6f4" FontSize="13" Margin="8,0,0,0"/>
                        </Grid>
                        <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" Margin="0,0,0,4">
                            <Run FontWeight="Bold" Foreground="#cdd6f4">Send → Pico</Run>  ส่ง schedule ทั้งหมดไปบันทึกลง SD card ของ Pico&#10;<Run FontWeight="Bold" Foreground="#cdd6f4">Pull ← Pico</Run>  ดึง schedule จาก SD card ของ Pico มาแสดงใน GUI&#10;<Run FontWeight="Bold" Foreground="#cdd6f4">Save File</Run>    บันทึก schedule เป็นไฟล์ .json ลงเครื่อง PC&#10;<Run FontWeight="Bold" Foreground="#cdd6f4">Load File</Run>    โหลดไฟล์ .json กลับมาแสดงใน GUI
                        </TextBlock>

                        <Rectangle Height="1" Fill="#313244" Margin="0,12,0,12"/>

                        <!-- ── Serial Commands ── -->
                        <TextBlock Text="Serial Commands (อ้างอิง)" Foreground="#89b4fa" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" Margin="0,0,0,6">
                            สามารถส่งคำสั่งโดยตรงจากช่อง Serial Console ด้านล่างซ้าย
                        </TextBlock>

                        <!-- Command table -->
                        <Border Background="#181825" CornerRadius="6" Padding="12,10" Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="Playback" Foreground="#6c7086" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock FontFamily="Consolas" FontSize="13" Foreground="#cdd6f4" TextWrapping="Wrap">
                                    <Run Foreground="#a6e3a1">play</Run>  /  <Run Foreground="#a6e3a1">pause</Run>  /  <Run Foreground="#a6e3a1">stop</Run>  /  <Run Foreground="#a6e3a1">next</Run>  /  <Run Foreground="#a6e3a1">prev</Run>&#10;<Run Foreground="#a6e3a1">goto</Run> <Run Foreground="#fab387">&lt;trackname&gt;</Run>    — กระโดดไปยัง track (ไม่ต้องใส่นามสกุล)&#10;<Run Foreground="#a6e3a1">status</Run>            — แสดงสถานะปัจจุบัน&#10;<Run Foreground="#a6e3a1">version</Run>           — แสดง firmware version
                                </TextBlock>

                                <TextBlock Text="Volume &amp; EQ" Foreground="#6c7086" FontSize="13" Margin="0,12,0,6"/>
                                <TextBlock FontFamily="Consolas" FontSize="13" Foreground="#cdd6f4" TextWrapping="Wrap">
                                    <Run Foreground="#a6e3a1">volume</Run> <Run Foreground="#fab387">&lt;0-100&gt;</Run>&#10;<Run Foreground="#a6e3a1">eq band</Run> <Run Foreground="#fab387">&lt;0-31&gt; &lt;-12..12&gt;</Run>&#10;<Run Foreground="#a6e3a1">eq reset</Run>&#10;<Run Foreground="#a6e3a1">mono on</Run>|<Run Foreground="#a6e3a1">off</Run>
                                </TextBlock>

                                <TextBlock Text="Repeat Mode" Foreground="#6c7086" FontSize="13" Margin="0,12,0,6"/>
                                <TextBlock FontFamily="Consolas" FontSize="13" Foreground="#cdd6f4" TextWrapping="Wrap">
                                    <Run Foreground="#a6e3a1">mode repeat_one</Run>      — วนซ้ำ track เดิม&#10;<Run Foreground="#a6e3a1">mode repeat_all</Run>      — วนทุก track&#10;<Run Foreground="#a6e3a1">mode repeat_off</Run>      — ไม่วน&#10;<Run Foreground="#a6e3a1">mode repeat_single</Run>   — เล่น track เดียวแล้วหยุด&#10;<Run Foreground="#a6e3a1">mode autoplay_on</Run>|<Run Foreground="#a6e3a1">off</Run>  — เล่นอัตโนมัติตอน boot
                                </TextBlock>

                                <TextBlock Text="Date / Time" Foreground="#6c7086" FontSize="13" Margin="0,12,0,6"/>
                                <TextBlock FontFamily="Consolas" FontSize="13" Foreground="#cdd6f4" TextWrapping="Wrap">
                                    <Run Foreground="#a6e3a1">date</Run> <Run Foreground="#fab387">YYYY-MM-DD HH:MM:SS</Run>&#10;<Run Foreground="#a6e3a1">time</Run> <Run Foreground="#fab387">HH:MM:SS</Run>
                                </TextBlock>

                                <TextBlock Text="Scheduler" Foreground="#6c7086" FontSize="13" Margin="0,12,0,6"/>
                                <TextBlock FontFamily="Consolas" FontSize="13" Foreground="#cdd6f4" TextWrapping="Wrap">
                                    <Run Foreground="#a6e3a1">sched list</Run>&#10;<Run Foreground="#a6e3a1">sched clear</Run>&#10;<Run Foreground="#a6e3a1">sched save</Run>&#10;<Run Foreground="#a6e3a1">sched add</Run> <Run Foreground="#fab387">time=HH:MM [stop=HH:MM] tracks=n1,n2 [loops=N] [days=1111111] [enabled=1]</Run>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Rectangle Height="1" Fill="#313244" Margin="0,12,0,12"/>

                        <!-- ── Tips ── -->
                        <TextBlock Text="เคล็ดลับ" Foreground="#89b4fa" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" Margin="0,0,0,5">
                                • ชื่อไฟล์ใน Tracks ไม่ต้องใส่นามสกุล (.mp3/.wav/.flac) และไม่ต้องสนใจตัวพิมพ์เล็ก-ใหญ่
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" Margin="0,0,0,5">
                                • loops = 0 คือวนไม่รู้จบจนกว่าถึงเวลา Stop หรือกด Stop เอง
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" Margin="0,0,0,5">
                                • 1 loop นับเป็น 1 รอบของ playlist ทั้งหมด ไม่ใช่ 1 เพลง
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" Margin="0,0,0,5">
                                • ไฟล์ schedule บน Pico อยู่ที่ <Run FontFamily="Consolas" Foreground="#fab387">0:/config/schedule.txt</Run>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" Margin="0,0,0,5">
                                • ค่า EQ และ volume บันทึกลง SD อัตโนมัติเมื่อเปลี่ยน
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" Margin="0,0,0,5">
                                • ถ้า port ไม่ขึ้น ให้กด Refresh หรือถอด-เสียบ USB ใหม่
                            </TextBlock>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
