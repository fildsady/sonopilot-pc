<Window x:Class="PicoHidConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PicoAudioCore — HID Console" Height="520" Width="700"
        Background="#1e1e2e" Foreground="#cdd6f4"
        FontFamily="Consolas" FontSize="13">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="PicoAudioCore" Foreground="#cba6f7" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="  HID Console" Foreground="#585b70" FontSize="18"/>
        </StackPanel>

        <!-- ── Connect bar ── -->
        <Border Grid.Row="1" Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="VID: 0x2E8A  PID: 0xC0DE" Foreground="#6c7086"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#f38ba8"
                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="TbStatus" Text="Disconnected" Foreground="#6c7086"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button x:Name="BtnConnect" Content="Connect" Click="BtnConnect_Click"
                        Background="#313244" Foreground="#a6e3a1" BorderBrush="#a6e3a1"
                        BorderThickness="1" Padding="14,5" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- ── Log ── -->
        <Border Grid.Row="2" Background="#11111b" CornerRadius="6" Padding="2" Margin="0,0,0,12">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TbLog" Foreground="#cdd6f4" FontFamily="Consolas"
                           FontSize="12" TextWrapping="Wrap" Padding="10"/>
            </ScrollViewer>
        </Border>

        <!-- ── Input bar ── -->
        <Border Grid.Row="3" Background="#313244" CornerRadius="6" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&gt;" Foreground="#a6e3a1"
                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                <TextBox x:Name="TbInput" Grid.Column="1"
                         Background="Transparent" Foreground="#cdd6f4"
                         BorderThickness="0" CaretBrush="#cdd6f4"
                         KeyDown="TbInput_KeyDown" IsEnabled="False"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Content="ping"    Click="BtnPing_Click"    IsEnabled="False" x:Name="BtnPing"
                            Background="#1e1e2e" Foreground="#89b4fa" BorderBrush="#45475a"
                            BorderThickness="1" Padding="10,3" Margin="2,0" Cursor="Hand"/>
                    <Button Content="info"    Click="BtnInfo_Click"    IsEnabled="False" x:Name="BtnInfo"
                            Background="#1e1e2e" Foreground="#89b4fa" BorderBrush="#45475a"
                            BorderThickness="1" Padding="10,3" Margin="2,0" Cursor="Hand"/>
                    <Button Content="led on"  Click="BtnLedOn_Click"   IsEnabled="False" x:Name="BtnLedOn"
                            Background="#1e1e2e" Foreground="#a6e3a1" BorderBrush="#45475a"
                            BorderThickness="1" Padding="10,3" Margin="2,0" Cursor="Hand"/>
                    <Button Content="led off" Click="BtnLedOff_Click"  IsEnabled="False" x:Name="BtnLedOff"
                            Background="#1e1e2e" Foreground="#f38ba8" BorderBrush="#45475a"
                            BorderThickness="1" Padding="10,3" Margin="2,0" Cursor="Hand"/>
                    <Button Content="Send ↵"  Click="BtnSend_Click"    IsEnabled="False" x:Name="BtnSend"
                            Background="#45475a" Foreground="#cdd6f4" BorderBrush="#585b70"
                            BorderThickness="1" Padding="12,3" Margin="8,0,0,0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
