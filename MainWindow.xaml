<Window x:Class="RP2350Player.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RP2350 Player  v1.0" Icon="/RP2350Player;component/app.ico" Height="590" Width="896"
        Background="#1e1e2e" Foreground="White"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background"      Value="#313244"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45475a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#585b70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b4befe"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="190"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Connection bar -->
        <Border Grid.Row="0" Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#cdd6f4"/>
                <ComboBox  Grid.Column="1" x:Name="CbPort" Height="28" BorderBrush="#45475a">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background"           Value="#1e1e2e"/>
                            <Setter Property="Foreground"           Value="White"/>
                            <Setter Property="BorderBrush"         Value="#45475a"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1" CornerRadius="4"/>
                                            <ContentPresenter x:Name="ContentSite"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                              Margin="8,0,28,0" VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"
                                                              TextElement.Foreground="White"/>
                                            <ToggleButton Focusable="False"
                                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                                              RelativeSource={RelativeSource TemplatedParent}}"
                                                          ClickMode="Press"
                                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                                        <Setter Property="Background"            Value="Transparent"/>
                                                        <Setter Property="BorderThickness"       Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="Transparent"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <TextBlock Text="▾" Foreground="White" FontSize="10"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Margin="0,0,8,0" IsHitTestVisible="False"/>
                                            <Popup x:Name="Popup" Placement="Bottom"
                                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                                    <Border Background="#313244" BorderBrush="#45475a" BorderThickness="1" CornerRadius="4">
                                                        <ScrollViewer>
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Grid>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="ItemContainerStyle">
                                <Setter.Value>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                        <Setter Property="Foreground"  Value="White"/>
                                        <Setter Property="Background"  Value="#313244"/>
                                        <Setter Property="Padding"     Value="8,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBoxItem">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <TextBlock Text="{TemplateBinding Content}"
                                                                   Foreground="White" FontSize="13"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsHighlighted" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#585b70"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#45475a"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>
                <Button    Grid.Column="2" x:Name="BtnRefresh" Content="⟳" Style="{StaticResource DarkBtn}"
                           Margin="6,0" Width="32" Click="BtnRefresh_Click"/>
                <Button    Grid.Column="3" x:Name="BtnConnect" Content="Connect" Style="{StaticResource AccentBtn}"
                           Width="100" Click="BtnConnect_Click"/>
                <TextBlock Grid.Column="4" x:Name="TbFirmware" Text=""
                           Foreground="#6c7086" FontSize="11" FontFamily="Consolas"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0"/>
                <Ellipse   Grid.Column="5" x:Name="StatusDot" Width="12" Height="12"
                           Fill="#f38ba8" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Transport controls -->
        <Border Grid.Row="1" Background="#313244" CornerRadius="6" Padding="16,12" Margin="0,0,0,12">
            <StackPanel>
                <TextBox x:Name="TbNowPlaying" Text="— Not connected —"
                         FontSize="14" FontWeight="Bold" Foreground="#cdd6f4"
                         HorizontalAlignment="Center" Margin="0,0,0,4"
                         IsReadOnly="True" BorderThickness="0"
                         Background="Transparent" TextAlignment="Center"
                         SelectionBrush="#89b4fa" Cursor="IBeam"/>
                <!-- elapsed time + track info row -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock x:Name="TbElapsed" Text="--:--" FontFamily="Consolas" FontSize="13"
                               Foreground="#a6e3a1" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TbTrackInfo" Text="" FontSize="12"
                               Foreground="#6c7086" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnPrev"  Content="⏮  Prev"  Style="{StaticResource DarkBtn}"  Width="90" Margin="4,0" IsEnabled="False" Click="BtnPrev_Click"/>
                    <Button x:Name="BtnPlay"  Content="▶  Play"  Style="{StaticResource AccentBtn}" Width="90" Margin="4,0" IsEnabled="False" Click="BtnPlay_Click"/>
                    <Button x:Name="BtnPause" Content="⏸  Pause" Style="{StaticResource DarkBtn}"  Width="90" Margin="4,0" IsEnabled="False" Click="BtnPause_Click"/>
                    <Button x:Name="BtnStop"  Content="⏹  Stop"  Style="{StaticResource DarkBtn}"  Width="90" Margin="4,0" IsEnabled="False" Click="BtnStop_Click"/>
                    <Button x:Name="BtnNext"  Content="Next  ⏭" Style="{StaticResource DarkBtn}"  Width="90" Margin="4,0" IsEnabled="False" Click="BtnNext_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="Go to:" VerticalAlignment="Center" Foreground="#a6adc8" Margin="0,0,8,0"/>
                    <TextBox x:Name="TbGoto" Width="220" Background="#1e1e2e" Foreground="White"
                             BorderBrush="#45475a" Padding="6,4" KeyDown="TbGoto_KeyDown"
                             ToolTip="Filename without extension, press Enter"/>
                    <Button x:Name="BtnGoto" Content="Go" Style="{StaticResource DarkBtn}"
                            Width="48" Margin="6,0,0,0" IsEnabled="False" Click="BtnGoto_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Playback mode -->
        <Border Grid.Row="2" Background="#313244" CornerRadius="6" Padding="16,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Repeat:" VerticalAlignment="Center" Foreground="#a6adc8" Width="60"/>
                        <Button x:Name="BtnRepeatOne" Content="⟳  One"  Style="{StaticResource DarkBtn}" Width="90" Margin="0,0,6,0" IsEnabled="False" Click="BtnRepeatOne_Click"/>
                        <Button x:Name="BtnRepeatAll" Content="⟳  All"  Style="{StaticResource DarkBtn}" Width="90" Margin="0,0,6,0" IsEnabled="False" Click="BtnRepeatAll_Click"/>
                        <Button x:Name="BtnRepeatOff" Content="✕  Off"  Style="{StaticResource DarkBtn}" Width="90" Margin="0,0,0,0" IsEnabled="False" Click="BtnRepeatOff_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="AutoPlay:" VerticalAlignment="Center" Foreground="#a6adc8" Width="60"/>
                        <Button x:Name="BtnAutoPlay" Content="▶  Auto On" Style="{StaticResource DarkBtn}" Width="110" IsEnabled="False" Click="BtnAutoPlay_Click"/>
                    </StackPanel>
                </StackPanel>
                <!-- File info -->
                <Border Grid.Column="1" Background="#1e1e2e" CornerRadius="4" Margin="16,0,0,0" Padding="10,6">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TbFileCodec"    Text="—" Foreground="#89b4fa" FontFamily="Consolas" FontSize="12"/>
                        <TextBlock x:Name="TbFileSampleRate" Text="" Foreground="#a6adc8" FontFamily="Consolas" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Time sync -->
        <Border Grid.Row="3" Background="#313244" CornerRadius="6" Padding="16,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="RTC:" VerticalAlignment="Center" Foreground="#a6adc8" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TbPcTime" Text="--:--:--" FontFamily="Consolas" FontSize="14"
                               Foreground="#a6e3a1" VerticalAlignment="Center" Width="180"/>
                    <Button x:Name="BtnSyncTime" Content="Sync PC Time → Board" Style="{StaticResource DarkBtn}"
                            Margin="12,0,0,0" IsEnabled="False" Click="BtnSyncTime_Click"/>
                </StackPanel>
                <!-- Volume -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="Vol:" Foreground="#a6adc8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="SlVolume" Minimum="0" Maximum="100" Value="80" Width="120"
                            VerticalAlignment="Center" IsEnabled="False"
                            ValueChanged="SlVolume_ValueChanged"/>
                    <TextBlock x:Name="TbVolume" Text="80%" Foreground="#cdd6f4" FontFamily="Consolas"
                               FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0" Width="36"/>
                    <!-- Mono/Stereo toggle -->
                    <Border x:Name="MonoToggleBorder" Width="64" Height="24" CornerRadius="12"
                            Background="#45475a" Margin="12,0,0,0" Cursor="Hand"
                            MouseLeftButtonUp="MonoToggle_Click" IsEnabled="False">
                        <Grid>
                            <TextBlock x:Name="TbMonoLabel" Text="STEREO" FontSize="9" FontWeight="Bold"
                                       Foreground="#a6adc8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse x:Name="MonoThumb" Width="18" Height="18" Fill="#cdd6f4"
                                     HorizontalAlignment="Left" Margin="3,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 32-Band EQ -->
        <Border Grid.Row="4" Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="32-Band EQ" Foreground="#a6adc8" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button x:Name="BtnEqReset" Content="Flat Reset" Style="{StaticResource DarkBtn}"
                            FontSize="10" Padding="8,3" IsEnabled="False" Click="BtnEqReset_Click"/>
                    <TextBlock Text="  0=-12dB  100=flat  200=+12dB" Foreground="#45475a"
                               FontSize="10" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                <StackPanel x:Name="EqPanel" Grid.Row="1" Orientation="Horizontal"/>
            </Grid>
        </Border>

        <!-- Log -->
        <Border Grid.Row="5" Background="#181825" CornerRadius="6" Padding="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                    <TextBlock Text="Serial Log" Foreground="#6c7086" FontSize="11"/>
                    <Button x:Name="BtnClearLog" Content="Clear" Style="{StaticResource DarkBtn}"
                            FontSize="10" Padding="6,2" Margin="8,0,0,0" Click="BtnClearLog_Click"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TbLog" FontFamily="Consolas" FontSize="11"
                               Foreground="#cdd6f4" Padding="8,4" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
        <!-- Hotkey panel -->
        <Border Grid.Column="2" Grid.RowSpan="6" Background="#313244" CornerRadius="6" Padding="10,10">
            <StackPanel>
                <TextBlock Text="Hotkeys" Foreground="#a6adc8" FontSize="11"
                           Margin="0,0,0,8" HorizontalAlignment="Center"/>
                <StackPanel x:Name="HotkeyPanel"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
